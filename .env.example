# VITE_GEMINI_API_KEY: Required for Gemini AI API calls (preferred for Vite).
VITE_GEMINI_API_KEY="<ADD_YOUR_API_KEY>"

# GEMINI_API_KEY: Legacy key supported by vite.config.ts define().
GEMINI_API_KEY="<ADD_YOUR_API_KEY>"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_OPENAI_API_KEY: Optional fallback key for OpenAI.
VITE_OPENAI_API_KEY="<ADD_YOUR_OPENAI_KEY>"
